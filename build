#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 [-h] [apk|apk-debug]"
  echo "  -h        Show help"
  exit 1
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
fi

target="${1:-apk}"
version="$(node -p "require('./package.json').version")"
output_dir="apks"
output_name="aniparser-${version}.apk"
output_path="${output_dir}/${output_name}"

copy_apk() {
  local apk_path="$1"
  mkdir -p "$output_dir"
  cp "$apk_path" "$output_path"
  echo "Copied: $output_path"
}

case "$target" in
  apk)
    ./android/gradlew assembleRelease
    copy_apk "android/app/build/outputs/apk/release/app-release.apk"
    ;;
  apk-debug)
    ./android/gradlew assembleDebug
    copy_apk "android/app/build/outputs/apk/debug/app-debug.apk"
    ;;
  *)
    usage
    ;;
esac
